// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "webpack-dev",
			"problemMatcher": {
				"owner": "webpack",
				"pattern": {
					"regexp": "^(.*)$",
					"message": 1
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*webpack.*",
					"endsPattern": "^webpack\\s+\\d+\\..*compiled.*$"
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			}
		},
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "watch-all",
			"dependsOn": [
				"npm: webpack-dev",
				"npm: watch"
			],
			"dependsOrder": "parallel",
			"problemMatcher": []
		}
	]
}
